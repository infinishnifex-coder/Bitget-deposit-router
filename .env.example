# KyberSwap Aggregator is used for swaps — no API key or KYC required.
# The two variables below are all you need.

# WalletConnect Cloud project id (https://cloud.reown.com) — free signup, no KYC.
# Without this, WalletConnect QR won't work, but MetaMask/Rabby/Coinbase Wallet still do.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: a dedicated Base RPC (Alchemy/Infura/QuickNode free tier).
# Falls back to https://mainnet.base.org (public, may be rate-limited under heavy use).
NEXT_PUBLIC_BASE_RPC_URL=
